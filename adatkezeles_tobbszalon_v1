struct WineRecord{
    char name[20];
    char table[20];
    char grape_type[20];
    int area;              // négyszögöl 
    int destruction;       //%
};

char file[] = "boraszat.dat";   

void append(struct WineRecord* x)
{
    int f = open(file, O_APPEND | O_CREAT | O_RDWR, S_IRUSR | S_IWUSR);
    if (f!=-1) printf("Fájl sikeresen létrehozva!\n");
    else{
        perror("Sikeretelen fajl letrehozas."); return;
    }

    int w = write(f, x, sizeof(*x));
    if (w!=-1) printf("Rekord sikeresen hozzáadva!\n");
    else{
        perror("Sikeretelen hozzáadása rekordnak:\n"); return;
    }

    close(f);
}

void show_full()
{
    int index = 0;
    int f = open(file, O_RDONLY, S_IRUSR | S_IWUSR);
    if (f==-1) {perror("Hiba show()-ban"); return;}

    struct WineRecord temp;
    while (read(f, &temp, sizeof(temp)) > 0)
    {   
        printf("%d\n", ++index);
        printf("Név: %s , Tábla: %s , Fajta: %s , Terület: %d négyszögöl, Pusztítás: %d%%\n",
               temp.name, temp.table, temp.grape_type, temp.area, temp.destruction);
    }
    close(f);
}

void show_bytable(const char* t)
{
    int f = open(file, O_RDONLY, S_IRUSR | S_IWUSR);
    if (f==-1) {perror("Hiba show()-ban"); return;}

    struct WineRecord temp;
    while (read(f, &temp, sizeof(temp)) > 0)
    {
        if (strcmp(temp.table, t) == 0){
            printf("Név: %s , Tábla: %s , Fajta: %s , Terület: %d négyszögöl, Pusztítás: %d%%\n",
                   temp.name, temp.table, temp.grape_type, temp.area, temp.destruction);
        }
    }
}

void show_bygrape_type(const char* g)
{
    int f = open(file, O_RDONLY, S_IRUSR | S_IWUSR);
    if (f==-1) {perror("Hiba show()-ban"); return;}

    struct WineRecord temp;
    while (read(f, &temp, sizeof(temp)) > 0)
    {
        if (strcmp(temp.grape_type, g) == 0){
            printf("Név: %s , Tábla: %s , Fajta: %s , Terület: %d négyszögöl, Pusztítás: %d%%\n",
                   temp.name, temp.table, temp.grape_type, temp.area, temp.destruction);
        }
    }
}

void delete(int i)
{
    int f = open(file, O_RDWR, S_IRUSR | S_IWUSR);
    if (f==-1) {perror("Hiba delete()-ben"); return;}


    struct WineRecord temp;
    if (lseek(f, (i+1) * sizeof(struct WineRecord), SEEK_SET) < 0)
    {
        {perror("Hiba delete()-ben"); return;}
    }

    while (read(f, &temp, sizeof(temp)) > 0)
    {
        if (lseek(f, i *sizeof(struct WineRecord), SEEK_SET) < 0)
        {
            perror("Hiba delete()-ben"); return;
        }

        if (write(f, &temp, sizeof(temp)) < 0)
        {
            perror("Hiba delete()-ben"); return;
        }

        if (lseek(f, (i+1) *sizeof(struct WineRecord), SEEK_SET) < 0)
        {
            perror("Hiba delete()-ben"); return;
        }

        i++;
    }

    if (ftruncate(f, lseek(f, 0, SEEK_END) - sizeof(struct WineRecord)) < 0)
    {
        perror("Hiba delete()-ben"); return;
    }


    close(f);
}

void update(int i)
{
    int f = open(file, O_RDWR, S_IRUSR | S_IWUSR);
    if (f==-1) {perror("Hiba update()-ban"); return;}

    struct WineRecord temp;
    if(lseek(f, (i) * sizeof(temp), SEEK_SET) < 0) {
        perror("Hiba update()-ban"); return;
    }

    int r = (read(f, &temp, sizeof(temp)));

    if (r < 0) {
        perror("Hiba update()-ban"); return;
    }
    else if (r == 0) {
        printf("Nincs mit módosítani.\n"); return;
    }

    int u_choice;

    do {
        printf("Melyik adaton szeretne módosítani?\n");
        printf("0 - Kilépés\n");
        printf("1 - Termőhely neve (%s)\n", temp.name);
        printf("2 - Tábla neve (%s)\n", temp.table);
        printf("3 - Szőlő típusa (%s)\n", temp.grape_type);
        printf("4 - Terület (%d)\n", temp.area);
        printf("5 - Pusztítás %% nélkül %d%%\n", temp.destruction);
        printf("Választás: ");
        scanf("%d", &u_choice);
        getchar();
    
        switch(u_choice)
        {
            case 0:
                break;

            case 1:
                printf("Új termőhely: ");
                fgets(temp.name, sizeof(temp.name), stdin);
                temp.name[strcspn(temp.name, "\n")] = 0;
                break;

            case 2:
                printf("Új tábla: ");
                fgets(temp.table, sizeof(temp.table), stdin);
                temp.table[strcspn(temp.table, "\n")] = 0;
                break;

            case 3:
                printf("Új szőlő típus: ");
                fgets(temp.grape_type, sizeof(temp.grape_type), stdin);
                temp.grape_type[strcspn(temp.grape_type, "\n")] = 0;
                break;

            case 4:
                printf("Új terület (négyszögölben): ");
                scanf("%d", &temp.area);
                getchar();
                break;

            case 5:
                printf("Új pusztítás (%%): ");
                scanf("%d", &temp.destruction);
                getchar();
                break;

            default:
                printf("Érvénytelen választás!\n");
        }
    } while (u_choice != 0);

    lseek(f, -sizeof(temp), SEEK_CUR);
    if (write(f, &temp, sizeof(temp)) < 0)
    {
        perror("Hiba update()-ban"); return;
    }

    close(f);
}


